# 1. Menutup akses ke file sensitif (Update Sintaks Apache 2.4 + Proteksi JSON)
<FilesMatch "\.(sqlite|lock|env|log|sh|json)$">
    Require all denied
</FilesMatch>

# 2. Mencegah penampilan daftar isi direktori
Options -Indexes

# 3. Mengamankan Service Worker (Biar update PWA langsung masuk)
<Files "sw.js">
    Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
</Files>

# 4. Mengatur agar Header dikirim dengan aman (Anti XSS & Clickjacking)
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>